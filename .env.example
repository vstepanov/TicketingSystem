# =============================================================================
# Ticketing System — environment configuration template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored and MUST NOT be committed. Never put real secrets here.
# Every variable below is validated at startup by src/lib/env.ts (Zod).
# `docker compose up --build` reads this file via the `env_file` directive.
# =============================================================================

# Node runtime mode: development | test | production
# Compose sets this to "production" for the web container.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL 18)
# -----------------------------------------------------------------------------
# Full connection string used by both the web app and the migrate step.
# The POSTGRES_* parts below are consumed by the `db` container to initialize
# the database; keep them consistent with DATABASE_URL.
#
# Host note: inside docker compose the host is the service name `db`.
#            For running tooling on your host machine, use `localhost`.
DATABASE_URL=postgres://ticketing:ticketing@db:5432/ticketing

# Individual Postgres parts (used by the `db` container's official image).
# These feed DATABASE_URL above; change all four together.
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing
POSTGRES_DB=ticketing
# Host port to expose the database on (container always listens on 5432).
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application / security
# -----------------------------------------------------------------------------
# Secret used to sign the HttpOnly session cookie (ADR-0002).
# MUST be at least 32 characters. Generate a fresh random value, e.g.:
#     openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Public base URL of the app (used to build links in verification emails).
APP_URL=http://localhost:3000

# Host port to expose the web container on.
WEB_PORT=3000

# -----------------------------------------------------------------------------
# SMTP (outbound verification email via Nodemailer)
# Credentials come from env only and are never committed (assumption §11.10).
# -----------------------------------------------------------------------------
# SMTP relay host. DataArt relay is the supported default.
SMTP_HOST=relay1.dataart.com
# SMTP port (587 = STARTTLS submission).
SMTP_PORT=587
# SMTP auth username (leave blank if the relay accepts unauthenticated mail).
SMTP_USER=
# SMTP auth password (leave blank if the relay accepts unauthenticated mail).
SMTP_PASS=
# "From" address / display name on outbound emails.
SMTP_FROM=Ticket Tracker <no-reply@dataart.com>
